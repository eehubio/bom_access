# Server-only DigiKey Product Search API credentials. Never prefix these with NEXT_PUBLIC_.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Optional locale settings (US/en/USD are the defaults).
DIGIKEY_LOCALE_SITE=US
DIGIKEY_LOCALE_LANGUAGE=en
DIGIKEY_LOCALE_CURRENCY=USD

# Set true only while validating a DigiKey Sandbox application.
DIGIKEY_USE_SANDBOX=false

# Server-only Mouser Search API key.
MOUSER_API_KEY=
